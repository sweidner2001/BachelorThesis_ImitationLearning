@online{wu_DiscretePolicyLearning_2025,
  title = {Discrete {{Policy}}: {{Learning Disentangled Action Space}} for {{Multi-Task Robotic Manipulation}}},
  shorttitle = {Discrete {{Policy}}},
  author = {Wu, Kun and Zhu, Yichen and Li, Jinming and Wen, Junjie and Liu, Ning and Xu, Zhiyuan and Tang, Jian},
  date = {2025-03-21},
  eprint = {2409.18707},
  eprinttype = {arXiv},
  eprintclass = {cs},
  doi = {10.48550/arXiv.2409.18707},
  url = {http://arxiv.org/abs/2409.18707},
  urldate = {2026-05-02},
  abstract = {Learning visuomotor policy for multi-task robotic manipulation has been a long-standing challenge for the robotics community. The difficulty lies in the diversity of action space: typically, a goal can be accomplished in multiple ways, resulting in a multimodal action distribution for a single task. The complexity of action distribution escalates as the number of tasks increases. In this work, we propose \textbackslash textbf\{Discrete Policy\}, a robot learning method for training universal agents capable of multi-task manipulation skills. Discrete Policy employs vector quantization to map action sequences into a discrete latent space, facilitating the learning of task-specific codes. These codes are then reconstructed into the action space conditioned on observations and language instruction. We evaluate our method on both simulation and multiple real-world embodiments, including both single-arm and bimanual robot settings. We demonstrate that our proposed Discrete Policy outperforms a well-established Diffusion Policy baseline and many state-of-the-art approaches, including ACT, Octo, and OpenVLA. For example, in a real-world multi-task training setting with five tasks, Discrete Policy achieves an average success rate that is 26\textbackslash\% higher than Diffusion Policy and 15\textbackslash\% higher than OpenVLA. As the number of tasks increases to 12, the performance gap between Discrete Policy and Diffusion Policy widens to 32.5\textbackslash\%, further showcasing the advantages of our approach. Our work empirically demonstrates that learning multi-task policies within the latent space is a vital step toward achieving general-purpose agents.},
  pubstate = {prepublished},
  keywords = {Computer Science - Robotics}
}
